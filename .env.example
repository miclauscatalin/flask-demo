# RO: Copiază acest fișier ca `.env` și completează valorile reale.
# EN: Copy this file as `.env` and fill in the real values.
#
# RO: Generează SECRET_KEY cu comanda:
# EN: Generate SECRET_KEY with:
#     python -c "import secrets; print(secrets.token_hex(32))"

# ──────────────────────────────────────────────────────────────
# RO: CHEIE SECRETĂ — obligatorie, fără ea aplicația nu pornește
# EN: SECRET KEY — required, the app won't start without it
# ──────────────────────────────────────────────────────────────
SECRET_KEY=GENEREAZA_UN_KEY_PUTERNIC_AICI

# ──────────────────────────────────────────────────────────────
# RO: Admin auto-creat la primul startup din aceste valori.
#     Poți schimba username/parola după ce te-ai logat.
# EN: Admin user is auto-created on first startup from these values.
#     You can change the username/password after logging in.
# ──────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=PAROLA_PUTERNICA_ADMIN_AICI
ADMIN_EMAIL=admin@yourdomain.com

# ──────────────────────────────────────────────────────────────
# RO: URL-ul aplicației — folosit în link-urile din emailuri.
#     Schimbă cu domeniul real la deploy.
# EN: App base URL — used in email links.
#     Change to your real domain when deploying.
# ──────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5000

# ──────────────────────────────────────────────────────────────
# RO: Baza de date — implicit SQLite local (recomandat pentru development).
#     Decomentează și schimbă pentru PostgreSQL în producție.
# EN: Database — default is local SQLite (recommended for development).
#     Uncomment and change for PostgreSQL in production.
# ──────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///app.db
# DATABASE_URL=postgresql://user:password@localhost/dbname

# ──────────────────────────────────────────────────────────────
# RO: Mod producție — decomentează pentru a activa cookie-uri HTTPS-only.
# EN: Production mode — uncomment to enable HTTPS-only secure cookies.
# ──────────────────────────────────────────────────────────────
# FLASK_ENV=production

# ──────────────────────────────────────────────────────────────
# RO: Email SMTP — opțional aici, poți configura din interfața web
#     după login ca admin (Navbar → SMTP).
#     Provider recomandat: brevo.com (300 emailuri/zi gratuit).
# EN: Email SMTP — optional here, can be configured from the web UI
#     after logging in as admin (Navbar → SMTP).
#     Recommended provider: brevo.com (300 emails/day free).
# ──────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Task Organizer

# ──────────────────────────────────────────────────────────────
# RO: Email de test — dacă e setat, toate reminder-urile merg
#     la această adresă în loc de emailul utilizatorului.
#     Util pentru testare locală. Lasă gol în producție.
# EN: Test email — if set, all reminders are sent to this address
#     instead of the user's own email.
#     Useful for local testing. Leave empty in production.
# ──────────────────────────────────────────────────────────────
# TEST_EMAIL=your@email.com
