# Copiază acest fișier ca `.env` și completează valorile reale.
# Generează SECRET_KEY cu: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=GENEREAZA_UN_KEY_PUTERNIC_AICI
# Utilizator admin auto-creat la startup
# / Admin user auto-created at startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=PAROLA_PUTERNICA_ADMIN_AICI
ADMIN_EMAIL=admin@yourdomain.com
# Opțional: schimbă URI-ul bazei de date (implicit SQLite local)
# DATABASE_URL=sqlite:///app.db

# Setează la "production" când dai deploy (activează HTTPS-only cookies)
# FLASK_ENV=production

# Brevo Email API (opțional — poți configura din interfața web)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Task Demo

# Email de test pentru remindere (opțional)
# TEST_EMAIL=your@email.com
